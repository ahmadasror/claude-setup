{
  "permissions": {
    "defaultMode": "default"
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/update-confluence.sh"
          }
        ]
      },
      {
        "matcher": "mcp__planka__cards",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sync-planka-to-claude-md.sh"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": false
}
